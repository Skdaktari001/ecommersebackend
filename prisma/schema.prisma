generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}


enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled

  @@map("order_status")
}

enum ReviewStatus {
  pending
  approved
  rejected

  @@map("review_status")
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String        @unique
  password     String
  phone        String?
  isAdmin      Boolean       @default(false) @map("is_admin")
  isActive     Boolean       @default(true) @map("is_active")
  profileImage String?       @map("profile_image")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp
  addresses    UserAddress[]
  orders       Order[]
  reviews      Review[]
  cartItems    CartItem[]

  @@map("users")
}

model UserAddress {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  street    String?
  city      String?
  county    String?
  country   String?  @default("Kenya")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model Product {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  category      String
  subCategory   String?        @map("sub_category")
  sizes         String[]
  isBestseller  Boolean        @default(false) @map("is_bestseller")
  averageRating Decimal        @default(0) @map("average_rating") @db.Decimal(2, 1)
  totalReviews  Int            @default(0) @map("total_reviews")
  reviewCounts  Json?          @map("review_counts")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp
  images        ProductImage[]
  orderItems    OrderItem[]
  reviews       Review[]
  cartItems     CartItem[]

  @@index([category], map: "idx_products_category")
  @@map("products")
}

model ProductImage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid @map("product_id")
  imageUrl  String  @map("image_url")
  isPrimary Boolean @default(false) @map("is_primary")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Order {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @db.Uuid @map("user_id")
  totalAmount   Decimal     @db.Decimal(10, 2) @map("total_amount")
  paymentMethod String      @map("payment_method")
  isPaid        Boolean     @default(false) @map("is_paid")
  address       Json?
  status        OrderStatus @default(pending)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  reviews       Review[]

  @@index([userId], map: "idx_orders_user")
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @db.Uuid @map("order_id")
  productId String?  @db.Uuid @map("product_id")
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])

  @@index([orderId], map: "idx_order_items_order")
  @@map("order_items")
}

model Review {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String       @db.Uuid @map("user_id")
  productId        String       @db.Uuid @map("product_id")
  orderId          String       @db.Uuid @map("order_id")
  rating           Int
  title            String?
  description      String?
  verifiedPurchase Boolean      @default(true) @map("verified_purchase")
  helpfulVotes     Int          @default(0) @map("helpful_votes")
  status           ReviewStatus @default(pending)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamp
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  images           ReviewImage[]

  @@unique([userId, productId, orderId])
  @@index([productId], map: "idx_reviews_product")
  @@map("reviews")
}

model ReviewImage {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId String @db.Uuid @map("review_id")
  imageUrl String @map("image_url")
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  productId String?  @db.Uuid @map("product_id")
  size      String
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])

  @@unique([userId, productId, size])
  @@index([userId], map: "idx_cart_user")
  @@map("cart_items")
}

